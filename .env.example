# browser-agent — .env.example
# Copy to `.env` and fill in.  All NIM endpoints are OpenAI-compatible
# (default base_url is NVIDIA's hosted NIM; override for self-hosted).

# === NIM provider registry ============================================
# The codebase reads NIM_{PROVIDER}_MODEL / _API_KEY / _BASE_URL for
# each known provider name (see src/shared/llm_client.py:_registry).
# Leave a provider blank to skip it; it just won't be available for voting.

NIM_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-pro
NIM_DEEPSEEK_API_KEY=
NIM_DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1

NIM_NEMOTRON_MODEL=nvidia/llama-3.1-nemotron-3-super-120b
NIM_NEMOTRON_API_KEY=
NIM_NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

NIM_MISTRAL_MODEL=mistralai/mistral-medium-3.5-128b
NIM_MISTRAL_API_KEY=
NIM_MISTRAL_BASE_URL=https://integrate.api.nvidia.com/v1

NIM_QWEN_MODEL=
NIM_QWEN_API_KEY=
NIM_QWEN_BASE_URL=https://integrate.api.nvidia.com/v1

NIM_GEMMA_MODEL=
NIM_GEMMA_API_KEY=
NIM_GEMMA_BASE_URL=https://integrate.api.nvidia.com/v1

# === Per-role provider assignment =====================================
# Comma-separated list of provider names from the registry above.
# Single name => K=1; multiple names => K=N ensemble vote.
# Defaults to "deepseek" if unset (see _role_providers fallback).

PLANNER_MODELS=nemotron
VALIDATOR_MODELS=nemotron,mistral

# === Reasoning / thinking toggles =====================================
# Per-role on/off — only applied when the provider's thinking_style supports it.
THINKING_PLANNER=off
THINKING_VALIDATOR=off

# Nemotron reasoning budget (tokens) when thinking is on.
NEMOTRON_REASONING_BUDGET=2048

# === NIM concurrency / retry =========================================
NIM_MAX_CONCURRENT=3
NIM_MAX_RETRY_ATTEMPTS=3
NIM_RETRY_BASE_DELAY=1.0

# === Postgres for selector cache =====================================
DATABASE_URL=postgresql://user:password@localhost:5432/browser_agent

# === SEC EDGAR compliance ============================================
# SEC requires a contact-email User-Agent: "name email@example.com".
# Used by the Actor's httpx fallback when fetching SEC pages.
SEC_USER_AGENT=interview-hw-2026 your-email@example.com
